{
  "name": "ingestify",
  "version": "1.0.3",
  "description": "A composable, pipeline-based data ingestion toolkit for Next.js and Node.js projects. Parse, chunk, transform, validate, and store data from any source.",
  "keywords": [
    "data-ingestion",
    "pipeline",
    "parser",
    "pdf",
    "docx",
    "csv",
    "excel",
    "chunking",
    "nextjs",
    "etl"
  ],
  "author": "Sachin Jat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sachinjat2802/ingestify.git"
  },
  "bugs": {
    "url": "https://github.com/sachinjat2802/ingestify/issues"
  },
  "homepage": "https://github.com/sachinjat2802/ingestify#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./parsers": {
      "types": "./dist/parsers/index.d.ts",
      "import": "./dist/parsers/index.js",
      "require": "./dist/parsers/index.cjs"
    },
    "./chunkers": {
      "types": "./dist/chunkers/index.d.ts",
      "import": "./dist/chunkers/index.js",
      "require": "./dist/chunkers/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs/index.d.ts",
      "import": "./dist/nextjs/index.js",
      "require": "./dist/nextjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.11.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.5",
    "react": "^19.2.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "mammoth": "^1.6.0",
    "next": "^14.0.0 || ^15.0.0",
    "papaparse": "^5.4.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.0.0 || ^19.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "pdf-parse": {
      "optional": true
    },
    "mammoth": {
      "optional": true
    },
    "papaparse": {
      "optional": true
    },
    "xlsx": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  }
}
